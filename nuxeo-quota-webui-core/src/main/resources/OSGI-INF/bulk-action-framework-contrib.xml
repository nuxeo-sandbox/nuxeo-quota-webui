<?xml version="1.0"?>
<component name="nuxeo.quota.webui.user.bulk" version="1.0">
  <require>org.nuxeo.ecm.core.bulk</require>
  <implementation class="nuxeo.quota.webui.user.UserQuotaInitialComputationAction"/>
  <extension target="org.nuxeo.ecm.core.bulk" point="actions">
    <action name="userQuotaInitialComputation"
            bucketSize="100"
            batchSize="50"
            httpEnabled="false"
            sequentialScroll="false"/>
  </extension>
  <extension target="org.nuxeo.runtime.stream.service" point="streamProcessor">
    <streamProcessor name="userQuotaInitialComputation"
                     defaultConcurrency="2"
                     defaultPartitions="4"
                     class="nuxeo.quota.webui.user.UserQuotaInitialComputationAction"/>
  </extension>
</component>
